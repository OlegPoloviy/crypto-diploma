# Production example for Render + Supabase.
# Do not commit real secrets. Add these values in the Render dashboard.

NODE_ENV=production
PORT=3000

# Supabase pooled connection string is usually the safest choice for hosted apps.
# Example shape:
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=
DATABASE_SSL=true
TYPEORM_LOGGING=false
