# Copy to .env for local development.
# These values match compose.yml defaults for Docker Postgres.

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=crypto
DATABASE_PASSWORD=crypto
DATABASE_NAME=crypto
DATABASE_SSL=false
TYPEORM_LOGGING=true

# Optional locally; recommended in production with Supabase/Render.
# DATABASE_URL=postgresql://crypto:crypto@localhost:5432/crypto

# Optional compose overrides if you set them in D:\diploma\.env.
# POSTGRES_USER=crypto
# POSTGRES_PASSWORD=crypto
# POSTGRES_DB=crypto
# POSTGRES_PORT=5432
