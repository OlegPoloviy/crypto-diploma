# Copy to .env and adjust. Matches compose.yml defaults when using Docker Postgres locally.

# --- App → PostgreSQL (host machine connecting to published port) ---
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=crypto
DATABASE_PASSWORD=crypto
DATABASE_NAME=crypto

# Single URL (optional; use if you prefer TypeORM url over discrete fields)
# DATABASE_URL=postgresql://crypto:crypto@localhost:5432/crypto

# --- Optional: override compose defaults (used if you set them in diploma/.env for docker compose) ---
# POSTGRES_USER=crypto
# POSTGRES_PASSWORD=crypto
# POSTGRES_DB=crypto
# POSTGRES_PORT=5432
